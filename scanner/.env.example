# ---- Notification channels (configure AT LEAST ONE) ----

# Telegram (recommended). Create a bot with @BotFather, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord (optional) — a channel webhook URL
DISCORD_WEBHOOK=

# ntfy.sh (optional) — easiest, no account. Pick a hard-to-guess topic and
# subscribe to it in the ntfy phone app.
NTFY_TOPIC=
# NTFY_URL=https://ntfy.sh   # only if self-hosting ntfy

# ---- Strategy / scan settings (optional, these are the defaults) ----
# Which signals to alert on: 'rsi' (RSI/RSI-MA cross), 'macd' (histogram reversal /
# first opposite-colour bar), or both. MACD flips are detected on the forming bar too.
SIGNALS=rsi,macd
TIMEFRAMES=5m,15m
RSI_LEN=14
MA_LEN=14
MA_TYPE=sma          # sma or ema (match the web tool)
TOP_N=50
SCAN_INTERVAL=60     # seconds between passes in --loop mode

# ---- Accuracy controls ----
# Each cross is scored 0-100 by stacking confirmations (MACD, ADX, higher-timeframe
# trend, EMA stack, volume, RSI zone, divergence, candle, volatility).
MIN_SCORE=58         # only alert at/above this score. 58≈B, 75≈A. Raise for fewer/cleaner.
USE_HTF=true         # confirm against the higher timeframe (5m→1h, 15m→4h) — strongest filter
REQUIRE_MACD=false   # true = also hard-require MACD agreement
