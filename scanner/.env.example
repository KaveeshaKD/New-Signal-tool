# ---- Notification channels (configure AT LEAST ONE) ----

# Telegram (recommended). Create a bot with @BotFather, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord (optional) — a channel webhook URL
DISCORD_WEBHOOK=

# ntfy.sh (optional) — easiest, no account. Pick a hard-to-guess topic and
# subscribe to it in the ntfy phone app.
NTFY_TOPIC=
# NTFY_URL=https://ntfy.sh   # only if self-hosting ntfy

# ---- Strategy / scan settings (optional, these are the defaults) ----
TIMEFRAMES=5m,15m
RSI_LEN=14
MA_LEN=14
MA_TYPE=sma          # sma or ema (match the web tool)
TOP_N=50
REQUIRE_MACD=false   # true = only alert when MACD also agrees (fewer, cleaner)
SCAN_INTERVAL=60     # seconds between passes in --loop mode
